{
  "name": "@maxmilton/oxlint-config",
  "version": "0.0.4",
  "description": "Shared oxlint configurations targeting the Bun ecosystem",
  "bugs": "https://github.com/maxmilton/oxlint-config/issues",
  "repository": "github:maxmilton/oxlint-config",
  "license": "MIT",
  "author": "Max Milton <max@2okki.com>",
  "type": "module",
  "main": "recommended.json",
  "files": [
    "pedantic.json",
    "recommended.json",
    "stage1.json"
  ],
  "scripts": {
    "lint": "bun lint:fmt && bun lint:js && bun lint:js2 && bun lint:ts",
    "lint:fmt": "biome check",
    "lint:js": "oxlint",
    "lint:js2": "eslint",
    "lint:ts": "tsc --noEmit",
    "test": "bun test --only-failures",
    "test:ci": "bun test --coverage --randomize --rerun-each=3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "10.0.1",
    "@maxmilton/eslint-config": "0.3.2",
    "@types/bun": "1.3.14",
    "eslint": "10.6.0",
    "eslint-plugin-oxlint": "1.72.0",
    "eslint-plugin-unicorn": "70.0.0",
    "oxlint": "1.72.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "peerDependencies": {
    "oxlint": "^1.72.0"
  }
}
